@page "/counter"
@rendermode InteractiveWebAssembly
@using Blazor.Redux
@using Blazor.Redux.Core
@using Blazor.Redux.Extensions
@using Blazor.Redux.Interfaces
@inject Store Store
@inject IDispatcher Dispatcher
@inject DispatchLogStore DispatchLogStore
@implements IDisposable

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="@(() => IncrementCount())">Click me</button>

<div class="mt-3">
    <h5>Middleware log</h5>
    <ul class="list-group">
        @foreach (var entry in DispatchLogStore.Entries)
        {
            <li class="list-group-item">@entry</li>
        }
    </ul>
    <button class="btn btn-sm btn-outline-secondary mt-2" @onclick="ClearLog">Clear log</button>
</div>

@code {
    private int currentCount = 0;
    private IDisposable? _subscription;
    private Action? _logSubscription;

    protected override void OnInitialized()
    {
        // Récupérer l'état initial
        currentCount = Store.GetSliceOrDefault<CounterSlice>() switch
        {
            { } slice => slice.Value,
            null => 0
        };

        // S'abonner aux changements si le Store implémente IObservableStore
        _subscription = Store.ObserveSlice<CounterSlice>()
            .Subscribe(slice =>
            {
                currentCount = slice.Value;
                InvokeAsync(StateHasChanged);
            });

        _logSubscription = () => InvokeAsync(StateHasChanged);
        DispatchLogStore.Changed += _logSubscription;
    }

    private void IncrementCount()
    {
        var action = new IncrementAction();
        Dispatcher.Dispatch<CounterSlice, IncrementAction>(action);
    }

    public void Dispose()
    {
        _subscription?.Dispose();
        if (_logSubscription != null)
        {
            DispatchLogStore.Changed -= _logSubscription;
        }
    }

    private void ClearLog()
    {
        DispatchLogStore.Clear();
    }
}
